# ─────────────────────────────────────────────────────────────────────────────
# sheet-dialer configuration
# Copy this file to `.env` and fill in the values. Never commit your real .env.
# ─────────────────────────────────────────────────────────────────────────────

# Set to "true" to run with a mocked telephony provider and a local JSON sheet.
# No Twilio or Google credentials are required in dry-run mode.
DRY_RUN=false

# ── Google Sheets ────────────────────────────────────────────────────────────
# Path to a Google service-account JSON key file.
# Share your spreadsheet with the service account's client_email (Editor access).
GOOGLE_CREDENTIALS_PATH=./google-credentials.json

# The spreadsheet ID (the long token in the sheet URL):
# https://docs.google.com/spreadsheets/d/<THIS_PART>/edit
SHEET_ID=

# The tab/sheet name to read from and write to.
SHEET_NAME=Sheet1

# Header names (row 1) the app looks for. Matching is case-insensitive.
PHONE_COLUMN=Phone
STATUS_COLUMN=Status
RESULT_COLUMN=Result

# ── Twilio ───────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# The Twilio number calls are placed FROM, E.164 format e.g. +15551234567
TWILIO_FROM_NUMBER=

# Publicly reachable base URL that Twilio can POST webhooks to.
# In local development use a tunnel, e.g. `ngrok http 3000` -> https://abc123.ngrok.app
PUBLIC_BASE_URL=

# ── Runtime tuning ───────────────────────────────────────────────────────────
PORT=3000
# Max seconds to record the automated system's response (Twilio transcription
# works best for English recordings under 2 minutes).
RECORD_MAX_LENGTH=60
# How long to wait for a single call to produce a result before giving up (ms).
CALL_TIMEOUT_MS=180000
# Pause between consecutive calls (ms).
DELAY_BETWEEN_CALLS_MS=2000
# Grace period after a call completes to wait for the async transcription (ms).
TRANSCRIPTION_GRACE_MS=20000

# Path to the local mock sheet used in dry-run mode.
MOCK_SHEET_PATH=./data/sample-sheet.json
