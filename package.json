{
  "name": "sheet-dialer",
  "version": "0.1.0",
  "type": "module",
  "description": "Automated outbound calling driven by a Google Sheet: call each number in turn, capture what the automated system says, and write the result back to the sheet.",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dry-run": "DRY_RUN=true node src/index.js",
    "test": "node --test"
  },
  "keywords": [
    "twilio",
    "google-sheets",
    "automation",
    "outbound-calling",
    "transcription"
  ],
  "license": "MIT",
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "googleapis": "^140.0.1",
    "twilio": "^5.3.0"
  },
  "engines": {
    "node": ">=18"
  }
}
